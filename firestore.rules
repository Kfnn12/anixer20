rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 256 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { 
      return request.auth != null && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'anonymous'); 
    }

    function isValidReview(data, animeId) {
      return data.keys().hasAll(['animeId', 'userId', 'username', 'userPhoto', 'rating', 'text', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 8
        && data.animeId == animeId
        && data.userId == request.auth.uid
        && data.username is string && data.username.size() <= 100
        && data.userPhoto is string && data.userPhoto.size() <= 1000
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.text is string && data.text.size() <= 2000
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidWatchlistItem(data, userId, animeId) {
      return data.keys().hasAll(['userId', 'animeId', 'title', 'image', 'createdAt'])
        && data.keys().size() >= 5 && data.keys().size() <= 8
        && data.userId == request.auth.uid
        && data.userId == userId
        && data.animeId == animeId
        && data.title is string && data.title.size() <= 200
        && data.image is string && data.image.size() <= 1000
        && data.createdAt is timestamp
        // Optional fields
        && (!('type' in data.keys()) || (data.type is string && data.type.size() <= 50))
        && (!('latestEpisode' in data.keys()) || (data.latestEpisode is number))
        && (!('lastCheckedAt' in data.keys()) || (data.lastCheckedAt is timestamp));
    }

    function isValidNotification(data, userId) {
      return data.keys().hasAll(['userId', 'animeId', 'title', 'message', 'type', 'read', 'createdAt'])
        && data.keys().size() == 7
        && data.userId == request.auth.uid
        && data.userId == userId
        && data.animeId is string
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 500
        && data.type is string && data.type.size() <= 50
        && data.read is bool
        && data.createdAt is timestamp;
    }

    function isValidWatchProgress(data, userId, animeId) {
      return data.keys().hasAll(['userId', 'animeId', 'title', 'image', 'episodeId', 'episodeNumber', 'currentTime', 'duration', 'updatedAt'])
        && data.keys().size() >= 9 && data.keys().size() <= 10
        && data.userId == request.auth.uid
        && data.userId == userId
        && data.animeId == animeId
        && data.title is string && data.title.size() <= 200
        && data.image is string && data.image.size() <= 1000
        && data.episodeId is string && data.episodeId.size() <= 200
        && data.episodeNumber is number
        && data.currentTime is number
        && data.duration is number
        && data.updatedAt is timestamp
        // Optional type field
        && (!('type' in data.keys()) || (data.type is string && data.type.size() <= 50));
    }

    match /users/{userId} {
      match /notifications/{notifId} {
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidNotification(incoming(), userId);
        allow update: if isSignedIn() && request.auth.uid == userId && isValidNotification(incoming(), userId)
          && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /watchlist/{animeId} {
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId && resource.data.userId == userId;
        
        allow create: if isSignedIn()
          && isValidId(userId)
          && isValidId(animeId)
          && isValidWatchlistItem(incoming(), userId, animeId)
          && incoming().createdAt == request.time;
        
        allow update: if isSignedIn() && request.auth.uid == userId
          && isValidWatchlistItem(incoming(), userId, animeId)
          && incoming().diff(existing()).affectedKeys().hasAny(['latestEpisode', 'lastCheckedAt']);
          
        allow delete: if isSignedIn() && request.auth.uid == userId && existing().userId == userId;
      }

      match /watchProgress/{animeId} {
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId && resource.data.userId == userId;
        
        allow create: if isSignedIn()
          && isValidId(userId)
          && isValidId(animeId)
          && isValidWatchProgress(incoming(), userId, animeId)
          && incoming().updatedAt == request.time;
          
        allow update: if isSignedIn()
          && request.auth.uid == userId
          && existing().userId == userId
          && isValidWatchProgress(incoming(), userId, animeId)
          && incoming().diff(existing()).affectedKeys().hasOnly(['episodeId', 'episodeNumber', 'currentTime', 'duration', 'updatedAt'])
          && incoming().updatedAt == request.time;
          
        allow delete: if isSignedIn() && request.auth.uid == userId && existing().userId == userId;
      }
    }

    match /anime/{animeId} {
      match /reviews/{reviewId} {
        allow get: if true; 
        allow list: if resource.data.animeId == animeId;

        allow create: if isSignedIn() 
          && isValidId(animeId)
          && isValidId(reviewId)
          && isValidReview(incoming(), animeId)
          && incoming().createdAt == request.time
          && incoming().updatedAt == request.time;

        allow update: if isSignedIn()
          && isValidReview(incoming(), animeId)
          && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'text', 'updatedAt'])
          && incoming().updatedAt == request.time
          && incoming().createdAt == existing().createdAt
          && incoming().animeId == existing().animeId
          && incoming().userId == existing().userId
          && existing().userId == request.auth.uid;

        allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      }
    }
  }
}
