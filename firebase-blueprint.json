{
  "entities": {
    "Review": {
      "title": "Review",
      "description": "A user's review and rating for an anime.",
      "type": "object",
      "properties": {
        "animeId": {
          "type": "string",
          "description": "ID of the anime being reviewed."
        },
        "userId": {
          "type": "string",
          "description": "ID of the user who wrote the review."
        },
        "username": {
          "type": "string"
        },
        "userPhoto": {
          "type": "string"
        },
        "rating": {
          "type": "number",
          "description": "Rating from 1 to 5."
        },
        "text": {
          "type": "string",
          "description": "The text of the review."
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp of creation."
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp of last update."
        }
      },
      "required": ["animeId", "userId", "username", "rating", "text", "createdAt", "updatedAt"]
    },
    "WatchlistItem": {
      "title": "WatchlistItem",
      "description": "An anime in the user's watchlist.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "animeId": { "type": "string" },
        "title": { "type": "string" },
        "image": { "type": "string" },
        "type": { "type": "string" },
        "latestEpisode": { "type": "number" },
        "lastCheckedAt": { "type": "number" },
        "createdAt": { "type": "number" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "animeId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}/watchlist/{animeId}": {
      "schema": { "$ref": "#/entities/WatchlistItem" },
      "description": "Stores user's bookmarked anime."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Stores user notifications."
    },
    "/anime/{animeId}/reviews/{reviewId}": {
      "schema": {
        "$ref": "#/entities/Review"
      },
      "description": "Stores user reviews for anime under each anime's subcollection."
    }
  }
}
